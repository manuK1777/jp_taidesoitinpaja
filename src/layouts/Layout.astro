---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Handcrafted Nordic and Central Asian folk instruments, made by hand in Karjalohja, Finland.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Taidesoitinpaja</title>
  </head>
  <body>
    <slot />
  </body>
</html>
