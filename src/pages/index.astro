---
import Layout from '../layouts/Layout.astro';
import InstrumentCard from '../components/InstrumentCard.astro';
import GalleryFilmstrip from '../components/GalleryFilmstrip.astro';
import Lightbox from '../components/Lightbox.astro';
import WorkshopModal from '../components/WorkshopModal.astro';
import { sanityClient } from '../lib/sanity';

// Static assets — 
import heroImage from '../assets/home-hero.jpg';
import heroImage2 from '../assets/home-our-story.jpg';
import workshopPoster from '../assets/luthier-workshop.png';
import { Image } from 'astro:assets';

const services = [
  {
    title: 'Artesanal Sound',
    tag: 'Crafted with care',
    body: 'Explore the selection of handcrafted folk instruments at Taidesoitinpaja. Each item is carefully made in our luthier workshop, reflecting outstanding artistry and quality. Take a look at our stunning range of igils, bowed lyres, air tunable drums and other folk instruments for sale. Every piece combines tradition and innovation, expertly crafted with dedication and skill.',
  },
  {
    title: 'Customized Design',
    tag: 'Personal touch',
    body: 'Transform your instrument with a personal touch by customizing it to suit your preferences. At Taidesoitinpaja, we partner with you to create a distinctive piece that showcases your style and sound. Let your creativity shine through our customization service, allowing your instrument to reflect your unique identity and resonate with your spirit.',
  },
  {
    title: 'Repair Service',
    tag: 'Restore & revive',
    body: 'Trust Taidesoitinpaja for instrument repairs. we are specialized in restoring and reviving your instruments to their former glory. Let us breathe new life into your beloved instrument.',
  },
  {
    title: 'Workshops & Events',
    tag: 'Join our interactive courses',
    body: 'Immerse yourself in the art of crafting instruments by participating in our engaging workshops. Learn the intricate process of drum making, build yourself a jouhikko (bowed lyre) or learn throat singing. Experience the joy of creating your own musical masterpiece.',
  },
];

const featuredInstruments = await sanityClient.fetch(`
  *[_type == "instrument"] | order(order asc) [0...6] {
    name,
    "slug": slug.current,
    price,
    "categoryTitle": instrumentType->title,
    "image": images[0]
  }
`);

const homePage = await sanityClient.fetch(`
  *[_type == "homePage"][0] {
    previousWorks[] { image, caption },
    workInProgress[] { image, caption }
  }
`);

const upcomingWorkshops = await sanityClient.fetch(`
  *[_type == "workshopEvent" && defined(startDateTime) && startDateTime > now()]
    | order(startDateTime asc) [0...4] {
    title, shortDescription, startDateTime, location
  }
`);
---

<Layout title="Home">
  <section class="hero container">
    <div class="hero__text">
      <h1>Unveiling<br/>musical<br/>magic</h1>
      <p class="hero__sub">Handcrafted Unique Instruments</p>
      <a href="/instruments" class="btn btn--solid">Learn More</a>
    </div>
    <div class="hero__image-wrap">
      <Image src={heroImage} alt="J-P Lilja's luthier workshop" class="hero__image" />
    </div>
  </section>

  <section class="instruments-band reveal">
    <div class="container">
      <div class="instruments-band__header">
        <div>
          <p class="eyebrow">Featured</p>
          <h2>Folk Instruments for Sale</h2>
        </div>
        <a href="/instruments" class="instruments-band__cta">View All Instruments →</a>
      </div>
      <div class="instruments-band__grid">
        {featuredInstruments.map((inst: any) => (
          <InstrumentCard
            name={inst.name}
            slug={inst.slug}
            price={inst.price}
            categoryTitle={inst.categoryTitle}
            image={inst.image}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="services container reveal">
    <h2 class="services__heading">Luthier Workshop Services</h2>
    <div class="services__layout">
      <div class="services__image-wrap">
        <video
          class="services__image"
          src="/video/luthier-workshop-optimized.mp4"
          poster={workshopPoster.src}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label="Inside J-P Lilja's luthier workshop"
        ></video>
      </div>
      <div class="services__list">
        {services.map((service) => (
          <div class="services__item">
            <h3>{service.title}</h3>
            <div class="services__tag">{service.tag}</div>
            <p>{service.body}</p>
            {service.title === 'Workshops & Events' && (
              <WorkshopModal events={upcomingWorkshops} />
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  {homePage?.previousWorks?.length > 0 && (
    <GalleryFilmstrip
      title="Previous works"
      items={homePage.previousWorks}
      imgWidth={500}
      imgHeight={650}
      itemWidth="260px"
    />
  )}

  {homePage?.workInProgress?.length > 0 && (
    <GalleryFilmstrip
      title="Work in Progress"
      items={homePage.workInProgress}
      imgWidth={360}
      imgHeight={450}
      itemWidth="200px"
      muted
    />
  )}

  <section class="our-story container reveal">
    <div class="our-story__content">
      <h2>Our Story</h2>
      <p class="eyebrow our-story__eyebrow">Crafting Musical Legacies</p>
      <p class="our-story__body">Taidesoitinpaja's journey is rooted in a deep passion 
        for preserving the rich essence of folk music through exquisitely handcrafted 
        instruments. Each creation embodies a unique story of heritage, quality, and 
        unwavering dedication to the art of instrument making. We invite you to embark 
        on this melodic voyage with us, where exceptional craftsmanship intertwines with boundless creativity, paving the way for a harmonious musical future.</p>
    </div>
    <div class="our-story__image-wrap">
      <Image src={heroImage2} alt="J-P Lilja at work in the workshop" class="our-story__image" />
    </div>
  </section>

  <!-- <div class="wide-banner">
    <Image src={heroImage2} alt="J-P Lilja at work in the workshop" class="wide-banner__image" />
  </div> -->
  <Lightbox />
</Layout>

<style>
  /* Hero */
  .hero {
    display: grid;
    gap: var(--space-4);
    align-items: center;
    padding-block: var(--space-5) var(--space-5);
  }
  @media (max-width: 899px) {
    .hero__text {
      text-align: center;
    }
  }
  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 0.85fr 1.15fr;
    }
  }
  .hero h1 {
    color: var(--color-brass);
    text-shadow:
    -1px -1px 1px oklch(10% 0.03 55.1 / 0.18),   /* shadow: darker, same hue */
     1px  1px 1px oklch(55% 0.04 60 / 0.7);   /* highlight: lighter, same hue */
  }
  .hero__sub {
    margin-block: var(--space-2) var(--space-3);
    font-size: 1.1rem;
  }

  .hero__image-wrap {
    border-radius: var(--radius);
    border: 12px solid #6b4c2e;
    box-shadow: 0 4px 12px rgb(0 0 0 / 20%);
    transition: transform 180ms ease, box-shadow 180ms ease;
    overflow: hidden;
    aspect-ratio: 16 / 16;
  }
  .hero__image-wrap :global(.hero__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Instruments band */
  .instruments-band {
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 62%)),
      url('/images/striped-wood-texture.webp') center / cover;
    padding-block: var(--space-5);
  }
  .instruments-band__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }
  .instruments-band__sub {
    margin-top: 0.4em;
  }
  .instruments-band__cta {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-cream);
    text-decoration: none;
    border-bottom: 2px solid var(--color-brass);
    padding-bottom: 3px;
    white-space: nowrap;
  }
  .instruments-band__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  @media (min-width: 700px) {
    .instruments-band__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Services */
  .services {
    padding-block: var(--space-5);
  }
  .services__heading {
    text-align: center;
    margin-bottom: var(--space-4);
  }
  .services__layout {
    display: grid;
    gap: var(--space-4);
  }
  .services__image-wrap {
    width: min(100%, 52rem);
    margin-inline: auto;
    border-radius: var(--radius);
    border: 12px solid #6b4c2e;
    box-shadow: 0 4px 12px rgb(0 0 0 / 20%);
    transition: transform 180ms ease, box-shadow 180ms ease;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    margin-bottom: 32px;
  }
  .services__image-wrap :global(.services__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .services__list {
    display: grid;
    gap: var(--space-4);
  }
  @media (min-width: 800px) {
    .services__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .services__item {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-3);
  }
  .services__item h3 {
    color: var(--color-brass);
    font-size: 1.375rem;
    margin-bottom: 4px;
  }
  .services__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }
  .services__item p {
    margin-bottom: 0.9em;
  }

  /* Our Story */
  .our-story {
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-5);
  }
  .our-story__content {
    max-width: 38rem;
    text-align: left;
  }
  .our-story__eyebrow {
    margin-block: 0.4em var(--space-2);
  }
  .our-story__body {
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .our-story__image-wrap {
    overflow: hidden;
    border: 12px solid #6b4c2e;
    border-radius: var(--radius);
    box-shadow: 0 4px 12px rgb(0 0 0 / 20%);
  }
  .our-story__image-wrap :global(.our-story__image) {
    width: 100%;
    height: 100%;
    aspect-ratio: 5 / 3;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 800px) {
    .our-story {
      grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 1.1fr);
      align-items: start;
    }
    }

  /* Wide banner */
  .wide-banner {
    aspect-ratio: 21 / 6;
    overflow: hidden;
  }
  .wide-banner :global(.wide-banner__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

</style>
