---
import Layout from '../layouts/Layout.astro';
import CarvedDivider from '../components/CarvedDivider.astro';
import InstrumentCard from '../components/InstrumentCard.astro';
import { sanityClient, urlFor } from '../lib/sanity';

// Static assets — place these files in src/assets/ (see setup notes below)
import heroImage from '../assets/home-hero.jpg';
import ourStoryImage from '../assets/home-our-story.jpg';
import logoIcon from '../assets/logo-icon.png';
import { Image } from 'astro:assets';

const featuredInstruments = await sanityClient.fetch(`
  *[_type == "instrument"] | order(order asc) [0...4] {
    name,
    "slug": slug.current,
    price,
    "categoryTitle": instrumentType->title,
    "image": images[0]
  }
`);

const homePage = await sanityClient.fetch(`
  *[_type == "homePage"][0] {
    previousWorks[] { image, caption },
    workInProgress[] { image, caption }
  }
`);

const nextEvent = await sanityClient.fetch(`
  *[_type == "workshopEvent" && defined(startDateTime) && startDateTime > now()]
    | order(startDateTime asc) [0] {
    title, shortDescription, startDateTime, location
  }
`);
---

<Layout title="Home">
  <header class="site-header">
    <div class="container site-header__inner">
      <a href="/" class="site-header__brand">
        <Image src={logoIcon} alt="Taidesoitinpaja" width={36} height={36} />
        <span>Taidesoitinpaja</span>
      </a>
      <nav class="site-header__nav">
        <a href="/instruments">Instruments</a>
        <a href="/workshops-events">Workshops &amp; Events</a>
        <a href="/repair-maintenance">Repair</a>
        <a href="/our-story">Our Story</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <Image src={heroImage} alt="" class="hero__image" />
    <div class="hero__scrim"></div>
    <div class="container hero__content">
      <p class="eyebrow">Karjalohja, Finland</p>
      <h1>Instruments carved<br />from patience and wood.</h1>
      <p class="hero__sub">Handcrafted igils, jouhikkos, doshpuluurs, and frame drums — each one built by hand, one at a time.</p>
      <a href="/instruments" class="btn btn--solid">See the instruments</a>
    </div>
  </section>

  <section class="container section reveal">
    <p class="eyebrow">Featured</p>
    <h2>From the workshop</h2>
    <div class="featured-grid">
      {featuredInstruments.map((inst: any) => (
        <InstrumentCard
          name={inst.name}
          slug={inst.slug}
          price={inst.price}
          categoryTitle={inst.categoryTitle}
          image={inst.image}
        />
      ))}
    </div>
  </section>

  <CarvedDivider />

  {homePage?.previousWorks?.length > 0 && (
    <section class="section reveal">
      <div class="container">
        <p class="eyebrow">Previous Works</p>
        <h2>Instruments that found a home</h2>
      </div>
      <div class="filmstrip">
        {homePage.previousWorks.map((item: any) => (
          <div class="filmstrip__item">
            <Image
              src={urlFor(item.image).width(500).height(650).fit('crop').auto('format').url()}
              alt={item.caption || ''}
              width={500}
              height={650}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {homePage?.workInProgress?.length > 0 && (
    <section class="section reveal">
      <div class="container">
        <p class="eyebrow">Work in Progress</p>
        <h2>Behind the scenes</h2>
      </div>
      <div class="filmstrip filmstrip--small">
        {homePage.workInProgress.map((item: any) => (
          <div class="filmstrip__item">
            <Image
              src={urlFor(item.image).width(360).height(450).fit('crop').auto('format').url()}
              alt={item.caption || ''}
              width={360}
              height={450}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <CarvedDivider flip />

  <section class="container section section--split reveal">
    <Image src={ourStoryImage} alt="J-P Lilja in his workshop" class="split__image" />
    <div class="split__content">
      <p class="eyebrow">Our Story</p>
      <h2>One luthier. One workshop. No shortcuts.</h2>
      <p>Every instrument that leaves Taidesoitinpaja is shaped, carved, and strung by hand in Karjalohja — a craft passed through patience rather than production lines.</p>
      <a href="/our-story" class="btn">Read our story</a>
    </div>
  </section>

  {nextEvent && (
    <section class="container section reveal">
      <p class="eyebrow">Coming up</p>
      <h2>{nextEvent.title}</h2>
      {nextEvent.shortDescription && <p>{nextEvent.shortDescription}</p>}
      <a href="/workshops-events" class="btn">See all workshops &amp; events</a>
    </section>
  )}

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <div>
        <Image src={logoIcon} alt="Taidesoitinpaja" width={40} height={40} />
        <p>Taidesoitinpaja</p>
      </div>
      <div>
        <p class="eyebrow">Address</p>
        <p>Lahdenperä 142, 09120 Karjalohja, Finland</p>
      </div>
      <div>
        <p class="eyebrow">Contact</p>
        <p>+358 40 575 5403<br />taidesoitinpaja@gmail.com</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-2);
  }
  .site-header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1.15rem;
  }
  .site-header__nav {
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .site-header__nav a {
    text-decoration: none;
    color: var(--color-text-muted);
  }
  .site-header__nav a:hover {
    color: var(--color-brass);
  }

  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero :global(.hero__image) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26,36,32,0.15) 0%, rgba(26,36,32,0.55) 60%, rgba(26,36,32,0.92) 100%);
  }
  .hero__content {
    position: relative;
    padding-bottom: var(--space-5);
    max-width: 40rem;
  }
  .hero__sub {
    margin-block: var(--space-2) var(--space-3);
    font-size: 1.1rem;
  }

  .section {
    padding-block: var(--space-5);
  }
  .section > .eyebrow {
    display: block;
    margin-bottom: var(--space-1);
  }
  .section h2 {
    margin-bottom: var(--space-3);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  @media (min-width: 900px) {
    .featured-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .filmstrip {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    padding-inline: var(--space-3);
    scroll-snap-type: x mandatory;
    padding-bottom: var(--space-1);
  }
  .filmstrip__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    width: 260px;
  }
  .filmstrip--small .filmstrip__item {
    width: 190px;
    filter: saturate(0.9);
  }
  .filmstrip__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-border);
  }

  .section--split {
    display: grid;
    gap: var(--space-4);
    align-items: center;
  }
  @media (min-width: 800px) {
    .section--split {
      grid-template-columns: 1fr 1fr;
    }
  }
  .section--split :global(.split__image) {
    width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
  }
  .split__content p {
    margin-block: var(--space-2);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-4);
    margin-top: var(--space-4);
  }
  .site-footer__inner {
    display: grid;
    gap: var(--space-3);
  }
  @media (min-width: 700px) {
    .site-footer__inner {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .site-footer p {
    margin-top: 0.4em;
  }
</style>
