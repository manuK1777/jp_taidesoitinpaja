---
// A thin, hand-drawn-style line tracing the silhouette of the moose-head
// scroll from the Taidesoitinpaja logo — echoes the horse-head scroll
// tradition on igil necks. Used as the section divider throughout the
// site, instead of a generic hairline rule.
interface Props {
  flip?: boolean;
}
const { flip = false } = Astro.props;
---

<div class="carved-divider" class:list={{ flip }} aria-hidden="true">
  <svg viewBox="0 0 400 40" preserveAspectRatio="none">
    <path
      d="M0,20
         C40,8 70,32 110,18
         C140,7 160,26 200,20
         C230,15 250,30 280,17
         C310,6 340,28 400,20"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="round"
    />
    <circle cx="200" cy="20" r="2.5" fill="currentColor" />
  </svg>
</div>

<style>
  .carved-divider {
    width: 100%;
    color: var(--color-brass);
    opacity: 0.55;
    margin-block: var(--space-4);
  }
  .carved-divider.flip {
    transform: scaleY(-1);
  }
  .carved-divider svg {
    width: 100%;
    height: 24px;
    display: block;
  }
</style>
