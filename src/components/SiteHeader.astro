---
import { Image } from 'astro:assets';
import logoIcon from '../assets/logo-icon.png';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Instruments', href: '/instruments' },
  { label: 'Repair & Maintenance', href: '/repair-maintenance' },
  { label: 'Workshops & Events', href: '/workshops-events' },
  { label: 'Our Story', href: '/our-story' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand">
      <Image src={logoIcon} alt="Taidesoitinpaja" width={170} class="site-header__logo" />
    </a>

    <button
      type="button"
      class="site-header__menu-toggle"
      id="site-nav-toggle"
      aria-label="Toggle navigation menu"
      aria-controls="site-nav"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-header__nav" id="site-nav">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  const navToggle = document.getElementById('site-nav-toggle');
  const nav = document.getElementById('site-nav');

  navToggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    navToggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      navToggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 12%)),
      url('/images/wood-mahogany.webp') center / cover;
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--color-border);
  }
  .site-header__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding-block: var(--space-2);
  }
  .site-header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    text-decoration: none;
    flex-shrink: 0;
  }
  .site-header__logo {
    background:
      linear-gradient(rgba(31, 36, 20, 0.06), rgb(36 27 20 / 6%)),
      url('/images/natural-wooden-background.webp') center / cover;
    padding-inline: 6px;
    height: auto;
    display: block;
    border: 1px solid #6b4c2e;
    border-radius: 5px;
    box-shadow:
      inset 0 1px rgb(255 245 220 / 32%),
      inset 0 -2px rgb(55 33 18 / 35%),
      0 3px 0 #4a2f1c,
      0 5px 10px rgb(0 0 0 / 25%);
  }
  .site-header__nav {
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 12%)),
      url('/images/wood-mahogany.webp') center / cover;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }
  .site-header__nav a {
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 12%)),
      url('/images/wood-spruce.webp') center / cover;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-cream);
    text-decoration: none;
    padding-block: 6px;
    padding-inline: 12px;
    border: 1px solid #6b4c2e;
    border-radius: 5px;
    box-shadow:
      inset 0 1px rgb(255 245 220 / 32%),
      inset 0 -2px rgb(55 33 18 / 35%),
      0 3px 0 #4a2f1c,
      0 5px 10px rgb(0 0 0 / 25%);
    text-shadow: 0 1px 1px rgb(0 0 0 / 35%);
    white-space: nowrap;
    transform: rotate(var(--nav-link-rotation, -0.25deg));
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
  }
  .site-header__nav a:nth-child(3n + 1) {
    --nav-link-rotation: -0.4deg;
  }
  .site-header__nav a:nth-child(3n + 2) {
    --nav-link-rotation: 0.3deg;
  }
  .site-header__nav a:nth-child(3n) {
    --nav-link-rotation: -0.2deg;
  }
  .site-header__nav a:hover {
    border-color: var(--color-brass);
    transform: translateY(-1px) rotate(var(--nav-link-rotation, -0.35deg));
    box-shadow:
      inset 0 1px rgb(255 245 220 / 38%),
      inset 0 -2px rgb(55 33 18 / 35%),
      0 4px 0 #4a2f1c,
      0 7px 12px rgb(0 0 0 / 28%);
  }
  .site-header__nav a:active {
    transform: translateY(2px) rotate(var(--nav-link-rotation, -0.35deg));
    box-shadow:
      inset 0 2px 4px rgb(55 33 18 / 45%),
      0 1px 0 #4a2f1c;
  }
  .site-header__menu-toggle {
    display: none;
    width: 42px;
    height: 38px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 12%)),
      url('/images/wood-spruce.webp') center / cover;
    border: 1px solid #6b4c2e;
    border-radius: 5px;
    box-shadow:
      inset 0 1px rgb(255 245 220 / 32%),
      inset 0 -2px rgb(55 33 18 / 35%),
      0 3px 0 #4a2f1c,
      0 5px 10px rgb(0 0 0 / 25%);
    padding: 0;
    color: var(--color-cream);
    cursor: pointer;
  }
  .site-header__menu-toggle span {
    width: 19px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    box-shadow: 0 1px rgb(0 0 0 / 35%);
  }
  .site-header__menu-toggle:active {
    transform: translateY(2px);
    box-shadow:
      inset 0 2px 4px rgb(55 33 18 / 45%),
      0 1px 0 #4a2f1c;
  }
  .site-header__menu-toggle:focus-visible {
    outline: 2px solid var(--color-brass);
    outline-offset: 3px;
  }

  @media (max-width: 1180px) and (min-width: 901px) {
    .site-header__nav {
      gap: var(--space-1);
      font-size: 0.8rem;
    }
  }
  @media (max-width: 900px) {
    .site-header__menu-toggle {
      display: flex;
    }
    .site-header__nav {
      display: none;
      position: absolute;
      inset-inline: 0;
      top: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-2) var(--space-3) var(--space-3);
    }
    .site-header__nav.is-open {
      display: flex;
    }
    .site-header__nav a {
      width: 100%;
      padding-block: 10px;
    }
  }
</style>
