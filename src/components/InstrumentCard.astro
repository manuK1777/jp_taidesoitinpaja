---
import { Image } from 'astro:assets';
import { urlFor } from '../lib/sanity';

interface Props {
  name: string;
  slug: string;
  price?: number;
  categoryTitle: string;
  image: any;
}

const { name, slug, price, categoryTitle, image } = Astro.props;
const imageUrl = image ? urlFor(image).width(600).height(750).fit('crop').auto('format').url() : null;
---

<a href={`/instruments/${slug}`} class="instrument-card">
  <div class="instrument-card__image">
    {imageUrl && <Image src={imageUrl} alt={name} width={600} height={750} loading="lazy" />}
  </div>
  <div class="instrument-card__meta">
    <h3 class="instrument-card__name">{name}</h3>
    <span class="instrument-card__category">{categoryTitle}</span>
    {price && <span class="instrument-card__price">€{price}</span>}
  </div>
</a>

<style>
  .instrument-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--color-bg);
    border: 8px solid #6b4c2e;
    border-radius: 5px;
    overflow: hidden;
    transform: rotate(var(--instrument-card-rotation, -0.35deg));
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .instrument-card:nth-child(3n + 1) {
    --instrument-card-rotation: -0.3deg;
  }

  .instrument-card:nth-child(3n + 2) {
    --instrument-card-rotation: 0.5deg;
  }

  .instrument-card:nth-child(3n) {
    --instrument-card-rotation: -0.2deg;
  }

  .instrument-card:hover {
    transform: translateY(-2px) rotate(var(--instrument-card-rotation, -0.35deg));
    box-shadow: 0 7px 12px rgb(0 0 0 / 28%);
  }

  .instrument-card__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-raised);
    box-shadow:
      inset 0 1px rgb(255 245 220 / 32%),
      inset 0 -2px rgb(55 33 18 / 35%),
      0 3px 0 #4a2f1c,
      0 5px 10px rgb(0 0 0 / 25%);
  }

  .instrument-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .instrument-card:hover .instrument-card__image img {
    transform: scale(1.03);
  }

  .instrument-card__meta {
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 12%)),
      url('/images/wood-bg-c-ash.webp') center / cover;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4em;
    flex: 1;
  }

  .instrument-card__name {
    font-size: 1.125rem;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  @media (max-width: 639px) {
    .instrument-card__name {
      font-size: 1rem;
    }
  }

  .instrument-card__category {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .instrument-card__price {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
    color: oklch(0.92 0.015 80);
  }
</style>
