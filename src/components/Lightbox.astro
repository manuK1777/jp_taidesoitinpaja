---
// Reusable lightbox. Include this component ONCE per page.
// Any element on the page can trigger it by adding:
//   data-lightbox-group="[gallery id]"      (groups images into one carousel)
//   data-lightbox-src="[full-size image URL]"
//   data-lightbox-alt="[description]"
//   data-lightbox-caption="[optional caption]"
// Clicking any element with data-lightbox-group opens the dialog showing
// every image sharing that same group value, starting at the clicked one.
---

<dialog id="lightbox" class="lightbox">
  <button type="button" class="lightbox__close" aria-label="Close">✕</button>
  <button type="button" class="lightbox__nav lightbox__nav--prev" aria-label="Previous image">‹</button>
  <figure class="lightbox__figure">
    <img class="lightbox__image" src="" alt="" />
    <figcaption class="lightbox__caption"></figcaption>
  </figure>
  <button type="button" class="lightbox__nav lightbox__nav--next" aria-label="Next image">›</button>
  <p class="lightbox__counter"></p>
</dialog>

<script>
  type LightboxItem = { src: string; alt: string; caption: string };

  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const imageEl = dialog.querySelector('.lightbox__image') as HTMLImageElement;
  const captionEl = dialog.querySelector('.lightbox__caption') as HTMLElement;
  const counterEl = dialog.querySelector('.lightbox__counter') as HTMLElement;
  const closeBtn = dialog.querySelector('.lightbox__close') as HTMLButtonElement;
  const prevBtn = dialog.querySelector('.lightbox__nav--prev') as HTMLButtonElement;
  const nextBtn = dialog.querySelector('.lightbox__nav--next') as HTMLButtonElement;

  let currentItems: LightboxItem[] = [];
  let currentIndex = 0;

  function render() {
    const item = currentItems[currentIndex];
    if (imageEl.src !== item.src) {
      dialog.classList.add('is-loading');
      imageEl.src = item.src;
    }
    imageEl.alt = item.alt;
    captionEl.textContent = item.caption;
    counterEl.textContent = `${currentIndex + 1} / ${currentItems.length}`;
  }

  imageEl.addEventListener('load', () => dialog.classList.remove('is-loading'));
  imageEl.addEventListener('error', () => dialog.classList.remove('is-loading'));

  function open(groupItems: LightboxItem[], startIndex: number) {
    currentItems = groupItems;
    currentIndex = startIndex;
    render();
    dialog.showModal();
  }

  function next() {
    currentIndex = (currentIndex + 1) % currentItems.length;
    render();
  }

  function prev() {
    currentIndex = (currentIndex - 1 + currentItems.length) % currentItems.length;
    render();
  }

  closeBtn.addEventListener('click', () => dialog.close());
  nextBtn.addEventListener('click', next);
  prevBtn.addEventListener('click', prev);

  // Click on the backdrop (outside the image/controls) closes it
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') next();
    if (e.key === 'ArrowLeft') prev();
    // Escape-to-close is native <dialog> behavior, no extra code needed
  });

  // Wire up every trigger element present on the page, grouped by
  // data-lightbox-group. Runs once on load — if you add gallery items
  // dynamically after this, re-run this same setup logic.
  function initTriggers() {
    const triggers = Array.from(
      document.querySelectorAll<HTMLElement>('[data-lightbox-group]')
    );

    const groups = new Map<string, LightboxItem[]>();
    triggers.forEach((el) => {
      const group = el.dataset.lightboxGroup!;
      const src = el.dataset.lightboxSrc || '';
      const alt = el.dataset.lightboxAlt || '';
      const caption = el.dataset.lightboxCaption || '';
      if (!groups.has(group)) groups.set(group, []);
      groups.get(group)!.push({ src, alt, caption });
    });

    // Track each trigger's index within its own group
    const indexWithinGroup = new Map<string, number>();
    triggers.forEach((el) => {
      const group = el.dataset.lightboxGroup!;
      const idx = indexWithinGroup.get(group) ?? 0;
      indexWithinGroup.set(group, idx + 1);

      const handler = () => open(groups.get(group)!, idx);
      el.addEventListener('click', handler);

      // Buttons/links are already focusable and keyboard-activatable;
      // only shim in a11y semantics for plain wrapper elements (e.g. a div).
      if (el.tagName !== 'BUTTON' && el.tagName !== 'A') {
        el.style.cursor = 'pointer';
        el.setAttribute('role', 'button');
        el.setAttribute('tabindex', '0');
        el.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            handler();
          }
        });
      }
    });
  }

  initTriggers();
</script>

<style>
  .lightbox {
    border: none;
    background: transparent;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
  }

  .lightbox::backdrop {
    background: rgba(26, 36, 32, 0.94);
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox__figure {
    display: grid;
    justify-items: center;
    gap: var(--space-2);
    margin: 0;
  }

  .lightbox__image {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    display: block;
    opacity: 1;
    transition: opacity 150ms ease;
  }

  .lightbox.is-loading .lightbox__image {
    opacity: 0;
  }

  .lightbox__caption {
    color: var(--color-text-muted);
    text-align: center;
  }

  .lightbox__caption:empty {
    display: none;
  }

  .lightbox__close,
  .lightbox__nav {
    position: fixed;
    background: transparent;
    border: 1px solid var(--color-brass);
    color: var(--color-cream);
    border-radius: var(--radius);
    font-size: 1.5rem;
    line-height: 1;
    padding: 0.5em 0.8em;
    cursor: pointer;
  }

  .lightbox__close:hover,
  .lightbox__nav:hover {
    background: var(--color-brass);
    color: var(--color-bg);
  }

  .lightbox__close {
    top: var(--space-2);
    right: var(--space-2);
  }

  .lightbox__nav--prev {
    left: var(--space-2);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox__nav--next {
    right: var(--space-2);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox__counter {
    position: fixed;
    bottom: var(--space-2);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 640px) {
    .lightbox__nav {
      font-size: 1.1rem;
      padding: 0.4em 0.6em;
    }
  }
</style>
