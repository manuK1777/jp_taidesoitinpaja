---
interface Props {
  direction: 'left' | 'right';
  ariaLabel: string;
  gradientId: string;
  scrollDirection?: 'left' | 'right';
}

const { direction, ariaLabel, gradientId, scrollDirection } = Astro.props;
const arrowPath = direction === 'left' ? 'M32 17 L19 28 L32 39' : 'M24 17 L37 28 L24 39';
---

<button
  type="button"
  class="wood-arrow-btn"
  data-scroll={scrollDirection}
  aria-label={ariaLabel}
>
  <svg viewBox="0 0 56 56" aria-hidden="true">
    <defs>
      <radialGradient id={gradientId} cx="35%" cy="30%" r="75%">
        <stop offset="0%" stop-color="#c9a06b" />
        <stop offset="100%" stop-color="#8a5f3a" />
      </radialGradient>
    </defs>
    <circle cx="28" cy="28" r="26" fill={`url(#${gradientId})`} stroke="#5c3d24" stroke-width="1.5" />
    <path d="M12 25 Q28 20 44 25 M12 31 Q28 36 44 31" fill="none" stroke="#5c3d24" stroke-width="0.6" opacity="0.35" />
    <path d={arrowPath} fill="none" stroke="#3e2a18" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4" transform="translate(0.8,0.8)" />
    <path d={arrowPath} fill="none" stroke="#faf3e6" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</button>

<style>
  .wood-arrow-btn {
    width: 40px;
    height: 40px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
  }

  .wood-arrow-btn svg {
    width: 100%;
    height: 100%;
  }

  .wood-arrow-btn:hover circle {
    filter: brightness(1.08);
  }

  .wood-arrow-btn:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
    border-radius: 50%;
  }
</style>
