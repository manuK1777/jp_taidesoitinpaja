---
interface Props {
  direction: 'left' | 'right';
  ariaLabel: string;
  gradientId: string;
  scrollDirection?: 'left' | 'right';
}

const { direction, ariaLabel, gradientId, scrollDirection } = Astro.props;
const arrowPath = direction === 'left'
  ? 'M46 21 H27 V13 L9 28 L27 43 V35 H46 Z'
  : 'M10 21 H29 V13 L47 28 L29 43 V35 H10 Z';
---

<button
  type="button"
  class="wood-arrow-btn"
  data-scroll={scrollDirection}
  aria-label={ariaLabel}
>
  <svg viewBox="0 0 56 56" aria-hidden="true">
    <defs>
      <linearGradient id={gradientId} x1="10" y1="13" x2="46" y2="43" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#d6af77" />
        <stop offset="52%" stop-color="#a87543" />
        <stop offset="100%" stop-color="#714524" />
      </linearGradient>
    </defs>
    <path d={arrowPath} fill="#4a2f1c" transform="translate(1.4,2.2)" />
    <path class="wood-arrow-btn__face" d={arrowPath} fill={`url(#${gradientId})`} stroke="#5c3d24" stroke-width="1.5" stroke-linejoin="round" />
    <path d={arrowPath} fill="none" stroke="rgb(255 245 220 / 28%)" stroke-width="1" stroke-linejoin="round" transform="translate(0,-1)" />
    <path d="M17 25 H34 M17 31 H34" fill="none" stroke="#5c3d24" stroke-width="0.65" opacity="0.32" />
  </svg>
</button>

<style>
  .wood-arrow-btn {
    width: 50px;
    height: 50px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    filter: drop-shadow(0 3px 2px rgb(0 0 0 / 28%));
    transition: transform 150ms ease, filter 150ms ease;
  }

  .wood-arrow-btn svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 639px) {
    .wood-arrow-btn {
      width: 46px;
      height: 46px;
    }
  }

  .wood-arrow-btn:hover {
    filter: drop-shadow(0 4px 4px rgb(0 0 0 / 32%));
    transform: translateY(-1px);
  }

  .wood-arrow-btn:hover .wood-arrow-btn__face {
    filter: brightness(1.08);
  }

  .wood-arrow-btn:active {
    filter: drop-shadow(0 1px 1px rgb(0 0 0 / 24%));
    transform: translateY(2px);
  }

  .wood-arrow-btn:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
    border-radius: 5px;
  }
</style>
