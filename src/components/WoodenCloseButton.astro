---
interface Props {
  ariaLabel: string;
  gradientId: string;
  className?: string;
}

const { ariaLabel, gradientId, className = '' } = Astro.props;
---

<button type="button" class:list={['wood-close-btn', className]} aria-label={ariaLabel}>
  <svg viewBox="0 0 56 56" aria-hidden="true">
    <defs>
      <linearGradient id={gradientId} x1="14" y1="14" x2="42" y2="42" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#d6af77" />
        <stop offset="52%" stop-color="#a87543" />
        <stop offset="100%" stop-color="#714524" />
      </linearGradient>
    </defs>
    <path d="M18 18 L38 38 M38 18 L18 38" fill="none" stroke="#4a2f1c" stroke-width="10" stroke-linecap="round" transform="translate(1.4,2.2)" />
    <path class="wood-close-btn__face" d="M18 18 L38 38 M38 18 L18 38" fill="none" stroke={`url(#${gradientId})`} stroke-width="10" stroke-linecap="round" />
    <path d="M18 18 L38 38 M38 18 L18 38" fill="none" stroke="rgb(255 245 220 / 28%)" stroke-width="1.2" stroke-linecap="round" transform="translate(0,-1.2)" />
  </svg>
</button>

<style>
  .wood-close-btn {
    width: 50px;
    height: 50px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    filter: drop-shadow(0 3px 2px rgb(0 0 0 / 28%));
    transition: transform 150ms ease, filter 150ms ease;
  }

  .wood-close-btn svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 639px) {
    .wood-close-btn {
      width: 46px;
      height: 46px;
    }
  }

  .wood-close-btn:hover {
    filter: drop-shadow(0 4px 4px rgb(0 0 0 / 32%));
    transform: translateY(-1px);
  }

  .wood-close-btn:hover .wood-close-btn__face {
    filter: brightness(1.08);
  }

  .wood-close-btn:active {
    filter: drop-shadow(0 1px 1px rgb(0 0 0 / 24%));
    transform: translateY(2px);
  }

  .wood-close-btn:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
    border-radius: 5px;
  }
</style>
