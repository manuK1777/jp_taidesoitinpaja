---
interface Props {
  ariaLabel: string;
  gradientId: string;
  className?: string;
}

const { ariaLabel, gradientId, className = '' } = Astro.props;
---

<button type="button" class:list={['wood-close-btn', className]} aria-label={ariaLabel}>
  <svg viewBox="0 0 56 56" aria-hidden="true">
    <defs>
      <radialGradient id={gradientId} cx="35%" cy="30%" r="75%">
        <stop offset="0%" stop-color="#c9a06b" />
        <stop offset="100%" stop-color="#8a5f3a" />
      </radialGradient>
    </defs>
    <circle cx="29" cy="30" r="25" fill="#4a2f1c" />
    <circle cx="28" cy="27" r="25" fill={`url(#${gradientId})`} stroke="#5c3d24" stroke-width="1.5" />
    <circle cx="28" cy="27" r="22.5" fill="none" stroke="rgb(255 245 220 / 28%)" stroke-width="1.2" />
    <path d="M12 24 Q28 19 44 24 M12 30 Q28 35 44 30" fill="none" stroke="#5c3d24" stroke-width="0.6" opacity="0.35" />
    <path d="M21 20 L35 34 M35 20 L21 34" fill="none" stroke="#3e2a18" stroke-width="5.5" stroke-linecap="round" opacity="0.45" transform="translate(1.2,2)" />
    <path d="M21 20 L35 34 M35 20 L21 34" fill="none" stroke="#faf3e6" stroke-width="4" stroke-linecap="round" />
  </svg>
</button>

<style>
  .wood-close-btn {
    width: 45px;
    height: 45px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    filter: drop-shadow(0 3px 2px rgb(0 0 0 / 28%));
    transition: transform 150ms ease, filter 150ms ease;
  }

  .wood-close-btn svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 639px) {
    .wood-close-btn {
      width: 36px;
      height: 36px;
    }
  }

  .wood-close-btn:hover {
    filter: drop-shadow(0 4px 4px rgb(0 0 0 / 32%));
    transform: translateY(-1px);
  }

  .wood-close-btn:hover circle:nth-of-type(2) {
    filter: brightness(1.08);
  }

  .wood-close-btn:active {
    filter: drop-shadow(0 1px 1px rgb(0 0 0 / 24%));
    transform: translateY(2px);
  }

  .wood-close-btn:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
    border-radius: 50%;
  }
</style>
