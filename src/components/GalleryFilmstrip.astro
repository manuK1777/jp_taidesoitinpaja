---
import { Image } from 'astro:assets';
import { urlFor } from '../lib/sanity';
import WoodArrowButton from './WoodArrowButton.astro';
import WoodenScrollBar from './WoodenScrollBar.astro';

interface GalleryItem {
  image: any;
  caption?: string;
}

interface Props {
  title: string;
  items: GalleryItem[];
  imgWidth: number;
  imgHeight: number;
  itemWidth?: string;
  muted?: boolean;
}

const { title, items, imgWidth, imgHeight, itemWidth = '260px', muted = false } = Astro.props;
const galleryId = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const galleryItems = items.map((item, index) => ({
  ...item,
  alt: item.caption || '',
  caption: item.caption || `Image ${index + 1}`,
  src: urlFor(item.image).width(imgWidth).height(imgHeight).fit('crop').auto('format').url(),
  lightboxSrc: urlFor(item.image).width(imgWidth * 3).height(imgHeight * 3).fit('crop').auto('format').url(),
}));
---

<section class="gallery-filmstrip" class:list={{ 'gallery-filmstrip--muted': muted }}>
  <div class="container gallery-filmstrip__header">
    <h2>{title}</h2>
  </div>
  <div class="gallery-filmstrip__carousel">
    <WoodArrowButton
      direction="left"
      ariaLabel="Scroll gallery left"
      gradientId={`${galleryId}-wood-gradient-left`}
      scrollDirection="left"
    />
    <div class="gallery-filmstrip__track" data-gallery-track id={`${galleryId}-track`}>
      {galleryItems.map((item) => (
        <button
          type="button"
          class="gallery-filmstrip__item"
          style={`width: ${itemWidth}`}
          data-lightbox-group={galleryId}
          data-lightbox-src={item.lightboxSrc}
          data-lightbox-alt={item.alt}
          data-lightbox-caption={item.caption}
        >
          <Image
            src={item.src}
            alt={item.alt}
            width={imgWidth}
            height={imgHeight}
            loading="lazy"
          />
        </button>
      ))}
    </div>
    <WoodArrowButton
      direction="right"
      ariaLabel="Scroll gallery right"
      gradientId={`${galleryId}-wood-gradient-right`}
      scrollDirection="right"
    />
  </div>
  <div class="gallery-filmstrip__scrollbar">
    <WoodenScrollBar for={`#${galleryId}-track`} />
  </div>
</section>

<script>
  const filmstrips = document.querySelectorAll<HTMLElement>('.gallery-filmstrip');

  filmstrips.forEach((filmstrip) => {
    const track = filmstrip.querySelector<HTMLElement>('[data-gallery-track]');
    if (!track) return;

    filmstrip.querySelectorAll<HTMLButtonElement>('[data-scroll]').forEach((button) => {
      button.addEventListener('click', () => {
        const direction = button.dataset.scroll === 'left' ? -1 : 1;
        track.scrollBy({ left: direction * 440, behavior: 'smooth' });
      });
    });
  });
</script>

<style>
  .gallery-filmstrip {
    /* background: var(--color-bg-raised); */
    background:
      linear-gradient(rgb(36 27 20 / 12%), rgb(36 27 20 / 62%)),
      url('/images/striped-wood-texture.webp') center / cover;
    padding-block: var(--space-4);
  }

  .gallery-filmstrip__header {
    max-width: 80%;
    margin-inline: auto;
    padding-inline: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .gallery-filmstrip__header .eyebrow {
    margin-bottom: 0.4em;
  }

  .gallery-filmstrip__header h2 {
    font-size: clamp(1.4rem, 3vw, 2.25rem);
  }


  .gallery-filmstrip__carousel {
    position: relative;
    width: 80%;
    margin-inline: auto;
  }

  .gallery-filmstrip__carousel :global(.wood-arrow-btn) {
    position: absolute;
    top: 50%;
    z-index: 1;
    transform: translateY(-50%);
  }

  .gallery-filmstrip__carousel :global(.wood-arrow-btn:first-child) {
    left: calc(-1 * (40px + var(--space-2)));
  }

  .gallery-filmstrip__carousel :global(.wood-arrow-btn:last-child) {
    right: calc(-1 * (40px + var(--space-2)));
  }

  @media (max-width: 639px) {
    .gallery-filmstrip__carousel {
      width: 92%;
    }

    .gallery-filmstrip__carousel :global(.wood-arrow-btn:first-child) {
      left: 0;
    }

    .gallery-filmstrip__carousel :global(.wood-arrow-btn:last-child) {
      right: 0;
    }
  }

  .gallery-filmstrip__track {
    max-width: none;
    margin-inline: auto;
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    scrollbar-width: none;
    padding-inline: var(--space-3);
    scroll-snap-type: x mandatory;
    padding-block: var(--space-1);
    margin-bottom: var(--space-2);
  }

  .gallery-filmstrip__track::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 640px) {
    .gallery-filmstrip__track {
      padding-inline: var(--space-4);
    }
  }

  .gallery-filmstrip__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    border: 0;
    border-radius: 6px;
    border: 6px solid #6b4c2e;
    box-shadow: 0 4px 12px rgb(0 0 0 / 20%);
    background: none;
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .gallery-filmstrip__item:hover {
    transform: scale(1.04);
    box-shadow: 0 8px 20px rgb(0 0 0 / 20%);
  }

  .gallery-filmstrip__item:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 3px;
  }

  .gallery-filmstrip--muted .gallery-filmstrip__item {
    filter: saturate(0.9);
  }

  .gallery-filmstrip__item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-filmstrip__scrollbar {
    max-width: 80%;
    margin: var(--space-1) auto 0;
    padding-inline: var(--space-3);
  }

  @media (min-width: 640px) {
    .gallery-filmstrip__scrollbar {
      padding-inline: var(--space-4);
    }
  }
</style>
